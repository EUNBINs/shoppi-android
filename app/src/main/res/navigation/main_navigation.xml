<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_navigation"
    app:startDestination="@id/navigation_home">

    <fragment
        android:id="@+id/navigation_cart"
        android:name="com.shoppi.android.fragment.CartFragment"
        android:label="CartFragment" >
        <action
            android:id="@+id/action_cartFragment_to_cartegoryFragment"
            app:destination="@id/navigation_category" />
        <action
            android:id="@+id/action_cartFragment_to_homeFragment"
            app:destination="@id/navigation_home" />
    </fragment>
    <fragment
        android:id="@+id/navigation_category"
        android:name="com.shoppi.android.fragment.CartegoryFragment"
        android:label="CartegoryFragment" >
        <action
            android:id="@+id/action_cartegoryFragment_to_homeFragment"
            app:destination="@id/navigation_home" />
        <action
            android:id="@+id/action_cartegoryFragment_to_cartFragment"
            app:destination="@id/navigation_cart" />
    </fragment>
    <fragment
        android:id="@+id/navigation_home"
        android:name="com.shoppi.android.fragment.HomeFragment"
        android:label="HomeFragment" >
        <action
            android:id="@+id/action_homeFragment_to_cartegoryFragment"
            app:destination="@id/navigation_category" />
        <action
            android:id="@+id/action_homeFragment_to_cartFragment2"
            app:destination="@id/navigation_cart" />
    </fragment>
</navigation>